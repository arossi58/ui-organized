{
  "name": "@ui-organized/storybook",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "storybook build",
    "preview": "npx http-server storybook-static -p 6007",
    "test:visual": "storybook build --quiet && playwright test",
    "test:visual:update": "storybook build --quiet && playwright test --update-snapshots",
    "test:visual:run": "playwright test"
  },
  "dependencies": {
    "@ui-organized/react": "workspace:*",
    "@ui-organized/storybook-inspector": "workspace:*",
    "@ui-organized/tokens": "workspace:*",
    "@ui-organized/utils": "workspace:*",
    "lucide-react": "^0.400.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "^10.4.4",
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/addon-themes": "^10.4.4",
    "@storybook/react": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@ui-organized/storybook-inspector": "workspace:*",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "http-server": "^14.1.1",
    "storybook": "^10.4.4",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
