# Copy to .env.local and fill in. .env.local is gitignored.

# Cloudflare Web Analytics beacon token (Cloudflare dashboard → Web Analytics →
# your site → JS snippet; the "token" value in data-cf-beacon). When set, the
# cookieless beacon loads and page views (incl. SPA route changes) are tracked.
# Unset → analytics off. Cookieless, so no consent banner is required.
VITE_CF_ANALYTICS_TOKEN=

# Cloudflare Turnstile site key. When set, the contact form renders the
# bot-verification widget. Unset → honeypot + submit-timing checks only.
VITE_TURNSTILE_SITE_KEY=

# Contact-form Worker URL (apps/marketing/worker). The form POSTs submissions
# here to send email + create the GitHub "Ideas" item. Unset → submissions are
# stubbed (logged in dev). e.g. https://contact.uiorganized.com
VITE_CONTACT_ENDPOINT=
