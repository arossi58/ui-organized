# Copy to .env.local and fill in. .env.local is gitignored.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). When set, gtag.js
# loads and page views are tracked across route changes. Unset → analytics off.
VITE_GA_MEASUREMENT_ID=

# Cloudflare Turnstile site key. When set, the contact form renders the
# bot-verification widget. Unset → honeypot + submit-timing checks only.
VITE_TURNSTILE_SITE_KEY=
