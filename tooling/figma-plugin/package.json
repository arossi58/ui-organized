{
  "name": "@ui-organized/figma-plugin",
  "version": "0.1.1",
  "private": true,
  "description": "Figma plugin that imports a UI Organized theme.json into Figma Variables — Primitives, Semantic (Light/Dark, aliasing Primitives), Scale and Typography collections.",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.0",
    "@tabler/icons-react": "^3.0.0",
    "@ui-organized/react": "workspace:*",
    "@ui-organized/tokens": "workspace:*",
    "@ui-organized/utils": "workspace:*",
    "lucide-react": "^0.400.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "@fontsource/roboto": "^5.2.10",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
