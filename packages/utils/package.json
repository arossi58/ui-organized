{
  "name": "@ui-organized/utils",
  "version": "2.0.0",
  "description": "Color generation, type scale, spacing, and semantic token resolution utilities for the ui-organized design system.",
  "keywords": [
    "design-system",
    "design-tokens",
    "color",
    "typography",
    "utilities"
  ],
  "license": "Apache-2.0",
  "author": "arossi58 <arossi5861@gmail.com>",
  "homepage": "https://github.com/arossi58/ui-organized/tree/main/packages/utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arossi58/ui-organized.git",
    "directory": "packages/utils"
  },
  "bugs": {
    "url": "https://github.com/arossi58/ui-organized/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ui-organized/schema": "workspace:*"
  },
  "devDependencies": {
    "@ui-organized/tsconfig": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
