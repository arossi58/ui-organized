{
  "name": "@ui-organized/react",
  "version": "0.1.1",
  "description": "React component library for the ui-organized design system, built on Base UI.",
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui",
    "base-ui",
    "accessible"
  ],
  "license": "Apache-2.0",
  "author": "arossi58 <arossi5861@gmail.com>",
  "homepage": "https://github.com/arossi58/ui-organized/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arossi58/ui-organized.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/arossi58/ui-organized/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --external react --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.400.0",
    "@tabler/icons-react": ">=3.0.0",
    "@heroicons/react": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    },
    "@tabler/icons-react": {
      "optional": true
    },
    "@heroicons/react": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@ui-organized/schema": "workspace:*",
    "@ui-organized/tokens": "workspace:*",
    "@ui-organized/utils": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0"
  },
  "devDependencies": {
    "@ui-organized/tsconfig": "workspace:*",
    "@heroicons/react": "^2.0.0",
    "@tabler/icons-react": "^3.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
