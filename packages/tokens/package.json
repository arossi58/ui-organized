{
  "name": "@ui-organized/tokens",
  "version": "0.1.1",
  "description": "Design tokens for the ui-organized design system: typed exports plus generated CSS custom properties, built with Style Dictionary.",
  "keywords": [
    "design-system",
    "design-tokens",
    "css-variables",
    "style-dictionary",
    "theme"
  ],
  "license": "Apache-2.0",
  "author": "arossi58 <arossi5861@gmail.com>",
  "homepage": "https://github.com/arossi58/ui-organized/tree/main/packages/tokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arossi58/ui-organized.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/arossi58/ui-organized/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./variables.css": "./output/variables.css"
  },
  "files": [
    "dist",
    "output",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "transform": "tsx transform.ts",
    "build:tokens": "tsx build.ts",
    "build": "tsx build.ts && tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ui-organized/schema": "workspace:*",
    "@ui-organized/utils": "workspace:*",
    "style-dictionary": "^4.0.0"
  },
  "devDependencies": {
    "@ui-organized/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
