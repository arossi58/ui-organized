{
  "name": "@ui-organized/react-vite",
  "version": "2.1.1",
  "description": "Vite plugin for the ui-organized design system: validates a theme config, runs the token pipeline, and injects CSS variables at build time and during dev with HMR.",
  "keywords": [
    "design-system",
    "design-tokens",
    "vite",
    "vite-plugin",
    "theme"
  ],
  "license": "Apache-2.0",
  "author": "arossi58 <arossi5861@gmail.com>",
  "homepage": "https://github.com/arossi58/ui-organized/tree/main/packages/react-vite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arossi58/ui-organized.git",
    "directory": "packages/react-vite"
  },
  "bugs": {
    "url": "https://github.com/arossi58/ui-organized/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ui-organized/schema": "workspace:*",
    "@ui-organized/tokens": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "devDependencies": {
    "@ui-organized/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
