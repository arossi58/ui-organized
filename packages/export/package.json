{
  "name": "@ui-organized/export",
  "version": "0.1.3",
  "description": "Export pipeline — resolves a DTCG project document (via @ui-organized/resolver, the authoritative oracle) into CSS custom properties with per-mode semantics. Style Dictionary + sd-transforms parity tested.",
  "keywords": [
    "design-tokens",
    "dtcg",
    "style-dictionary",
    "css",
    "export"
  ],
  "license": "Apache-2.0",
  "author": "arossi58 <arossi5861@gmail.com>",
  "homepage": "https://github.com/arossi58/ui-organized/tree/main/packages/export#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arossi58/ui-organized.git",
    "directory": "packages/export"
  },
  "bugs": {
    "url": "https://github.com/arossi58/ui-organized/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "uiorg-export": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ui-organized/schema": "workspace:*",
    "@ui-organized/resolver": "workspace:*",
    "@ui-organized/token-io": "workspace:*"
  },
  "devDependencies": {
    "@tokens-studio/sd-transforms": "^1.0.0",
    "@types/node": "^20.0.0",
    "@ui-organized/tsconfig": "workspace:*",
    "style-dictionary": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
