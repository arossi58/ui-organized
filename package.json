  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@turbo/gen": "^2.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0"
